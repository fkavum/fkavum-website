---
interface Props {
    title: string;
    subtitle?: string;
    date?: string;
    tags?: string[];
}

const { title, subtitle, date, tags = [] } = Astro.props;
---
<div class="card">
    <div class="card-header">
        <h3 class="pixel-font">{title}</h3>
        {date && <span class="dim">{date}</span>}
    </div>
    {subtitle && <p class="highlight">{subtitle}</p>}
    <slot />
    {tags.length > 0 && (
        <div class="tag-row">
            {tags.map(tag => <span class="tag">{tag}</span>)}
        </div>
    )}
</div>


