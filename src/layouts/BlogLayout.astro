---
const { title } = Astro.props;
---
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{title} | Fatih Kavum</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323&display=swap" rel="stylesheet">
    <style is:global>
        :root {
            --bg: #0a0a12;
            --primary: #00f2ff;
            --secondary: #ffe100;
            --accent: #ff00ff;
            --text: #e0e0e0;
            --card-bg: rgba(255, 255, 255, 0.03);
        }

        * { box-sizing: border-box; scroll-behavior: smooth; }
        
        body {
            background-color: var(--bg);
            color: var(--text);
            font-family: 'VT323', monospace;
            font-size: 1.4rem;
            line-height: 1.4;
            margin: 0;
            padding: 0;
            background: linear-gradient(rgba(18, 16, 16, 0) 50%, rgba(0, 0, 0, 0.1) 50%), var(--bg);
            background-size: 100% 4px;
        }

        .container { max-width: 800px; margin: 0 auto; padding: 0 20px; }
        
        h1, h2, h3, .pixel-font { font-family: 'Press Start 2P', cursive; text-transform: uppercase; }
        h1 { font-size: 2.2rem; color: var(--secondary); text-shadow: 4px 4px var(--accent); text-align: center; margin: 60px 0 30px; }
        
        .highlight { color: var(--primary); font-weight: bold; }
        .dim { color: #888; font-size: 0.9rem; }

        nav {
            position: sticky;
            top: 0;
            background: rgba(10, 10, 18, 0.95);
            padding: 20px 0;
            z-index: 100;
            border-bottom: 2px solid var(--primary);
            display: flex;
            justify-content: center;
            gap: 30px;
        }

        nav a {
            color: var(--text);
            text-decoration: none;
            font-family: 'Press Start 2P', cursive;
            font-size: 0.7rem;
            transition: 0.3s;
        }

        nav a:hover { color: var(--accent); transform: scale(1.1); }

        .back-btn { 
            display: inline-block; 
            margin-top: 40px;
            margin-bottom: 30px; 
            color: var(--accent); 
            text-decoration: none;
            cursor: pointer; 
            font-family: 'Press Start 2P'; 
            font-size: 0.7rem; 
        }
        .back-btn:hover { text-shadow: 2px 2px var(--secondary); }

        article { font-size: 1.5rem; color: #ccc; }
        article p { margin-bottom: 20px; }

        footer { text-align: center; padding: 80px 0; color: #555; font-size: 0.9rem; }
    </style>
</head>
<body>
    <nav>
        <a href="/">PROFILE</a>
        <a href="/logs">LOGS</a>
    </nav>
    <div class="container">
        <slot />
        <footer>
            <p>CONGRATULATIONS! YOU REACHED THE END. <br> fatihkavum@gmail.com | © 2026</p>
        </footer>
    </div>
</body>
</html>
