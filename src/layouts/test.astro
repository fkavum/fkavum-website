---
interface Props {
    title: string;
}
const { title } = Astro.props;
---

<!doctype html>
<html lang="tr">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
    </head>
    <!-- Tüm site için koyu tema arkaplanı ve standart font ayarı -->
    <body class="bg-gray-900 text-white min-h-screen p-8 font-sans">
        <div class="max-w-4xl mx-auto">
            <!-- Sayfa içerikleri buraya (slot) gelecek -->
            <slot />
        </div>
    </body>
</html>