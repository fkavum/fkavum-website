---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import BlogCard from "../components/BlogCard.astro";
import { blogs } from "../data/blogs";
---

<Layout title="Fatih Kavum | Portfolio">
    <Navigation />

    <div class="container">
        <header id="top">
            <h1>FATIH KAVUM</h1>
            <p style="font-size: 1.8rem;">
                Senior <span class="highlight">Game & Software</span> Engineer
            </p>
            <p class="dim">
                Liège, Belgium | <span style="color:var(--secondary)"
                    >50M+ Installs</span
                >
            </p>
            <div class="tag-row header-tags">
                <span class="tag">LVL 7+ YEARS EXP</span>
                <span class="tag">UNITY EXPERT</span>
                <span class="tag">BACKEND ARCHITECT</span>
            </div>
        </header>

        <Section id="about" title="PLAYER_PROFILE">
            <p style="font-size: 1.6rem; line-height: 1.6;">
                I build <span class="highlight">scalable systems</span> for high-traffic
                environments. Whether it's optimizing SQL queries from seconds to
                milliseconds [cite: 38] or architecting gameplay for <span
                    class="highlight">500k Daily Active Users</span
                >[cite: 22, 24], I focus on performance and reliability.
            </p>
        </Section>

        <Section id="exp" title="QUEST_LOG (EXPERIENCE)">
            <Card
                title="Zynga"
                subtitle="Senior Software Engineer"
                date="2022 - 2025"
                tags={[".NET", "AWS", "Unity", "CI/CD"]}
            >
                <p>
                    Managed backend-facing systems for <span class="highlight"
                        >50M+ installs</span
                    >. Engineered reconnection pipelines and content delivery
                    via Unity Addressables[cite: 24, 26, 55].
                </p>
            </Card>

            <Card
                title="Sir Studios"
                subtitle="Senior Software Developer"
                date="2021 - 2022"
                tags={["PlayFab", "Azure", "Scalability"]}
            >
                <p>
                    Led architecture for new products and maintained live
                    systems for <span class="highlight">200k+ DAU</span> using PlayFab
                    and Azure Functions[cite: 28, 30, 32].
                </p>
            </Card>

            <Card
                title="Playable Factory"
                subtitle="Software Developer"
                date="2020 - 2021"
            >
                <p>
                    Built a custom HTML5 engine to replicate Unity behavior,
                    keeping build sizes <span class="highlight"
                        >under 1.5MB</span
                    >[cite: 65, 66].
                </p>
            </Card>
        </Section>

        <Section id="skills" title="ABILITY_TREE (STATS)">
            <div class="skill-grid">
                <div>
                    <p class="pixel-font skill-label">CORE_TECH</p>
                    <ul class="skill-list">
                        <li>C# / .NET (Expert) [cite: 44, 70]</li>
                        <li>Unity (6+ Years) [cite: 49, 69]</li>
                        <li>SQL & NoSQL [cite: 44]</li>
                        <li>C++ / Unreal [cite: 49, 70]</li>
                    </ul>
                </div>
                <div>
                    <p class="pixel-font skill-label">INFRA_SKILLS</p>
                    <ul class="skill-list">
                        <li>AWS / Azure [cite: 27, 45, 58]</li>
                        <li>Jenkins / Docker [cite: 27, 45, 59]</li>
                        <li>Redis / Caching [cite: 40, 45]</li>
                        <li>Distributed Systems [cite: 21, 39]</li>
                    </ul>
                </div>
            </div>
        </Section>

        <Section id="blog" title="DEV_DIARY (BLOG)">
            {
                blogs.map((blog) => (
                    <BlogCard
                        title={blog.title}
                        description={blog.description}
                        date={blog.date}
                        category={blog.category}
                        slug={blog.slug}
                    />
                ))
            }
        </Section>

        <footer>
            <p class="dim">
                GAME OVER? NAH. <br /> CONTACT: fatihkavum@gmail.com [cite: 20, 48]
            </p>
        </footer>
    </div>
</Layout>

<style>
    header {
        height: 100vh;
    }

    h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .header-tags {
        justify-content: center;
        margin-top: 20px;
    }

    footer {
        padding: 50px 0;
        border: none;
    }
</style>

