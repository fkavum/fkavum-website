---
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";
import Section from "../components/Section.astro";
import Card from "../components/Card.astro";
import BlogCard from "../components/BlogCard.astro";
import resumeData from "../data/resume.json";
---

<Layout title="Fatih Kavum | Portfolio">
    <Navigation />

    <div class="container">
        <header id="top">
            <h1>FATIH KAVUM</h1>
            <p style="font-size: 1.8rem;">
                Senior <span class="highlight">Game & Software</span> Engineer
            </p>
            <p class="dim">
                Liège, Belgium | <span style="color:var(--secondary)"
                    >50M+ Installs</span
                >
            </p>
            <div class="tag-row header-tags">
                <span class="tag">LVL 7+ YEARS EXP</span>
                <span class="tag">UNITY EXPERT</span>
                <span class="tag">BACKEND ARCHITECT</span>
            </div>
        </header>

        <Section id="about" title="PLAYER_PROFILE">
            <p style="font-size: 1.6rem; line-height: 1.6;">
                I build <span class="highlight">scalable systems</span> for high-traffic
                environments. Whether it's optimizing SQL queries from seconds to
                milliseconds or architecting gameplay for <span
                    class="highlight">500k Daily Active Users</span
                >, I focus on performance and reliability.
            </p>
        </Section>

        <Section id="exp" title="QUEST_LOG (EXPERIENCE)">
            {
                resumeData.experience.map((exp) => (
                    <Card
                        title={exp.company}
                        subtitle={exp.role}
                        date={exp.period}
                        tags={exp.tags.length > 0 ? exp.tags : undefined}
                    >
                        <p set:html={exp.description} />
                    </Card>
                ))
            }
        </Section>

        <Section id="skills" title="ABILITY_TREE (STATS)">
            <div class="skill-grid">
                {
                    resumeData.skills.map((skillGroup) => (
                        <div>
                            <p class="pixel-font skill-label">{skillGroup.category}</p>
                            <ul class="skill-list">
                                {skillGroup.items.map((item) => (
                                    <li>{item}</li>
                                ))}
                            </ul>
                        </div>
                    ))
                }
            </div>
        </Section>
        <footer>
            <p class="dim">
                GAME OVER? NAH. <br /> CONTACT: fatihkavum@gmail.com
            </p>
        </footer>
    </div>
</Layout>

<style>
    header {
        height: 100vh;
    }

    h1 {
        font-size: 2.5rem;
        margin-bottom: 10px;
    }

    .header-tags {
        justify-content: center;
        margin-top: 20px;
    }

    footer {
        padding: 50px 0;
        border: none;
    }
</style>
