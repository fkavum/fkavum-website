---
import BlogLayout from '../../layouts/BlogLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { blogs } from '../../data/blogs';
---

<BlogLayout title="Dev Logs">
    <h1>DEV_LOGS</h1>
    <div class="blog-grid">
        {blogs.map((blog) => (
            <BlogCard 
                title={blog.title}
                description={blog.description}
                date={blog.date}
                category={blog.category}
                slug={blog.slug}
            />
        ))}
    </div>
    <a href="/" class="back-btn">&lt; RETURN_TO_PROFILE</a>
</BlogLayout>

<style>
    .blog-grid {
        display: grid; 
        grid-template-columns: 1fr; 
        gap: 20px; 
        margin-top: 40px;
    }
</style>

